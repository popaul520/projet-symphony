<!DOCTYPE html>
<html lang="fr">
<head>
    <meta http-equiv="content-type" content="text/html; charset=UTF-8">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Démo SF">
    <meta name="author" content="UGA/IUT2/INFO">
    <link rel="icon" href="{{ asset('images/favicon.ico') }}">
    <title>
        {% block title %}
            TODO : définir contenu block title
        {%  endblock %}
    </title>
    <link href="{{ asset('css/bootstrap-4/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/fontawsome-5.all.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/projet.css') }}" rel="stylesheet">
    {% block css %}{%  endblock %}
</head>
<div class="container mt-4">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
</div>
<body>
{% include "navbar.html.twig" %}
<main role="main" class="container-fluid">
    <div class="row">
        <div class="col-md-10">
            <div
                class="main-div">
                {%  block body %}
                    <h1>
                        <i>TODO : définir contenu block body</i>
                    </h1>
                {%  endblock %}
            </div>
        </div>
    </div>
</main>
<script src="{{ asset('js/jquery-3/jquery.slim.min.js') }}"></script>
<script src="{{ asset('js/bootstrap-4/bootstrap.bundle.min.js') }}"></script>
<script>
    $(function () {
        $('[data-toggle="tooltip"]').tooltip();

        $('#search-button').on('click', function() {
            onSearchClick($('#search-input').val());
        });
        $('#search-input').on('keypress', function(e) {
            if(e.which === 13) {
                e.preventDefault();
                onSearchClick($(this).val());
            }
        });
    });
    function onSearchClick(searchString) {
        if (searchString.length > 0) {
            let encodedSearch = encodeURIComponent(searchString);
            let url = "{{ path('app_boutique_chercher', {'recherche': 'RECH_VAL'}) }}".replace('RECH_VAL', encodedSearch);
            // Redirection
            window.location.href = url;
        }
    }
</script>
{% block js %}{%  endblock %}
</body>
</html>
