{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>Votre Panier</h1>

        {% if items is empty %}
            {# Affichage quand le panier est vide #}
            <div class="alert alert-info shadow-sm p-5 text-center">
                <h2 class="display-4">Ton panier est vide !</h2>
                <p class="lead">Voudrais-tu briser notre petit coeur fragile de commerçant ?</p>
                <hr class="my-4">
                <a href="{{ path('app_boutique_index') }}" class="btn btn-primary btn-lg">
                    <i class="fas fa-shopping-bag"></i> Retourner à la boutique
                </a>
            </div>
        {% else %}
            {# Affichage du tableau si le panier contient des produits #}
            <table class="table table-hover mt-4">
                <thead>
                <tr>
                    <th>Produit</th>
                    <th>Prix</th>
                    <th>Quantité</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr>
                        <td>{{ item.produit.libelle }}</td>
                        <td>{{ item.produit.prix }} €</td>
                        <td>
                            <a href="{{ path('app_panier_enlever', {'idProduit': item.produit.id}) }}" class="btn btn-sm btn-outline-secondary">-</a>
                            <span class="mx-2">{{ item.quantite }}</span>
                            <a href="{{ path('app_panier_ajouter', {'idProduit': item.produit.id}) }}" class="btn btn-sm btn-outline-secondary">+</a>
                        </td>
                        <td>{{ item.produit.prix * item.quantite }} €</td>
                        <td>
                            <a href="{{ path('app_panier_supprimer', {'idProduit': item.produit.id}) }}" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                <tr class="table-active font-weight-bold">
                    <td colspan="3" class="text-right">Total Général :</td>
                    <td>{{ total }} €</td>
                    <td></td>
                </tr>
                </tfoot>
            </table>

            <div class="d-flex justify-content-between mt-4">
                <a href="{{ path('app_panier_vider') }}" class="btn btn-outline-danger" onclick="return confirm('Vider tout le panier ?')">
                    <i class="fas fa-ghost"></i> Vider le panier
                </a>
                <button class="btn btn-success btn-lg">
                    <i class="fas fa-credit-card"></i> Passer la commande
                </button>
            </div>
        {% endif %}
    </div>
{% endblock %}
